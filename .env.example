# 智谱 GLM-4V API Key（疑难图分支必填）
ZHIPU_API_KEY=your_key_here

# 本地 VLM 模型路径（容器内路径，对应宿主机 ./models 挂载）
LOCAL_VLM_PATH=/app/models/qwen2.5-vl-7b-merge

# 本地模型设备与精度（GPU 部署用 cuda，CPU 部署用 cpu）
LOCAL_VLM_DEVICE=auto
LOCAL_VLM_DTYPE=auto

# 路由阈值
CONFIDENCE_THRESHOLD=0.75
COMPLEXITY_THRESHOLD=0.5
MULTI_OBJECT_MODE=false
TOOL_TIMEOUT=30

# 抠图 ONNX 权重文件名（位于 models/RMBG-2.0/onnx/）
RMBG_ONNX_MODEL=model_int8.onnx

# YOLO 检测配置
YOLO_DEVICE=cpu
YOLO_CONFIDENCE_THRESHOLD=0.4
YOLO_IOU_THRESHOLD=0.5
